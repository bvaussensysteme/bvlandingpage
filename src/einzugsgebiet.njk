extraStyles: |
      .gebiet-hero {
        background: var(--black); padding: 56px 0 48px;
        border-bottom: 3px solid var(--gold); position: relative;
      }
      .gebiet-hero::after {
        content: ''; position: absolute; bottom: -1px; left: 0; width: 100%; height: 40px;
        background: var(--white); clip-path: polygon(0 100%, 100% 20%, 100% 100%);
      }
      .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 14px; }
      .breadcrumb a { color: var(--gold); text-decoration: none; }
      .gebiet-hero h1 { color: var(--white); margin-bottom: 10px; font-size: clamp(1.9rem,5vw,3rem); }
      .gebiet-hero p  { color: rgba(255,255,255,0.75); max-width: 560px; font-size: 0.97rem; line-height: 1.7; }

      /* Layout */
      .gebiet-layout {
        display: grid; grid-template-columns: 1fr 340px;
        gap: 32px; margin-top: 40px; align-items: start;
      }

      /* Karte */
      #map {
        height: 540px; border-radius: 12px;
        box-shadow: var(--shadow-lg);
        border: 2px solid var(--border);
        z-index: 0;
      }

      /* Ortsliste */
      .orte-panel {
        background: var(--white); border-radius: 12px;
        box-shadow: var(--shadow); border: 1px solid var(--border);
        overflow: hidden;
      }
      .orte-panel-header {
        background: var(--black); padding: 18px 20px;
        border-bottom: 3px solid var(--gold);
      }
      .orte-panel-header h3 {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1.1rem; font-weight: 700; color: var(--white); margin: 0;
      }
      .orte-panel-header p { font-size: 0.78rem; color: rgba(255,255,255,0.55); margin-top: 3px; }
      .orte-list { list-style: none; padding: 8px 0; max-height: 460px; overflow-y: auto; }
      .orte-list li {
        padding: 0;
      }
      .orte-list button {
        width: 100%; text-align: left; background: none; border: none;
        padding: 11px 20px; cursor: pointer;
        display: flex; align-items: center; gap: 10px;
        font-family: 'Inter', sans-serif; font-size: 0.9rem; color: var(--text);
        transition: background 0.15s; border-bottom: 1px solid var(--border);
      }
      .orte-list li:last-child button { border-bottom: none; }
      .orte-list button:hover { background: var(--offwhite); color: var(--gold-dark); }
      .orte-list button.active { background: rgba(196,154,42,0.08); color: var(--gold-dark); font-weight: 600; }
      .orte-dot {
        width: 10px; height: 10px; border-radius: 50%;
        background: var(--gold); flex-shrink: 0;
        box-shadow: 0 0 0 3px rgba(196,154,42,0.2);
      }
      .orte-dot.hauptort { background: var(--black); box-shadow: 0 0 0 3px rgba(196,154,42,0.4); }
      .orte-dot.fern { background: #fff; border: 2px solid var(--muted); box-shadow: none; }
      .info-badge {
        display: inline-flex; align-items: center; justify-content: center;
        width: 15px; height: 15px; border-radius: 50%; flex-shrink: 0;
        background: rgba(0,0,0,0.12); color: var(--muted);
        font-size: 0.65rem; font-style: italic; font-family: Georgia, 'Times New Roman', serif;
        margin-left: 2px; cursor: help;
      }
      .info-badge:hover, .info-badge:focus-visible { background: var(--gold); color: #fff; }
      #gebietTip {
        display: none; position: fixed; z-index: 1000;
        background: var(--black); color: #fff;
        font-family: 'Inter', sans-serif; font-size: 0.76rem; font-style: normal;
        line-height: 1.5; padding: 9px 13px; border-radius: 8px;
        max-width: 230px; box-shadow: 0 6px 18px rgba(0,0,0,0.3);
      }

      /* Kartenpopup: Hintergrund kommt jetzt direkt vom Inhalt (inline
         style in bindPopup), da sich Leaflets eigener Wrapper-Hintergrund
         auf manchen Geräten nicht zuverlässig zeigte. Wrapper hier nur
         noch transparent/ohne eigenen Schatten, damit kein doppelter
         Kasten entsteht. */
      .bv-popup .leaflet-popup-content-wrapper {
        background: transparent;
        box-shadow: none;
        padding: 0;
      }
      .bv-popup .leaflet-popup-content { margin: 0; }
      .bv-popup .leaflet-popup-tip { background: #fff; }

      /* CTA unter Karte */
      .gebiet-cta {
        background: var(--black); border-radius: 12px;
        padding: 28px; text-align: center; margin-top: 24px;
        border: 1px solid rgba(196,154,42,0.25);
      }
      .gebiet-cta h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 1.3rem; color: var(--white); margin-bottom: 8px; }
      .gebiet-cta p  { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-bottom: 16px; }


      @media (max-width: 860px) {
        .gebiet-layout { grid-template-columns: 1fr; }
        #map { height: 400px; }
        .orte-list { max-height: 300px; }
      }

extraHead: |
